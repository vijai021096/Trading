# ─── Zerodha Kite API ─────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=                  # Auto-refreshed daily — leave blank initially
KITE_TOTP_SECRET=                   # Base32 TOTP secret from Zerodha (for auto login)
KITE_USER_ID=your_user_id
KITE_USER_PASSWORD=your_password

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nifty_trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_this_strong_password

# ─── API / Dashboard ──────────────────────────────────────────────
API_SECRET_KEY=change_this_jwt_secret_32chars
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this

# ─── Strategy Parameters ──────────────────────────────────────────
CAPITAL=100000.0
VIX_MAX=18.0
ATR_SL_MIN_PCT=0.08
ATR_SL_MAX_PCT=0.12
RR_MIN=2.5
MAX_DAILY_LOSS_PCT=0.03
MAX_TRADES_PER_DAY=3
PAPER_MODE=false

# ─── Notifications ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Environment ──────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
