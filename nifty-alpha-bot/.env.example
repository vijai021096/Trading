# ─── Zerodha Kite API ─────────────────────────────────────────────
# IMPORTANT: Set your Kite Connect app's Redirect URL to:
#   Local:  http://127.0.0.1:8000/api/kite/callback
#   Cloud:  https://your-domain.com/api/kite/callback
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=
KITE_TOTP_SECRET=
KITE_USER_ID=your_user_id
KITE_USER_PASSWORD=your_password

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nifty_trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_this_strong_password

# ─── API / Dashboard ──────────────────────────────────────────────
API_SECRET_KEY=change_this_jwt_secret_32chars
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this

# ─── Capital & Risk ──────────────────────────────────────────────
CAPITAL=25000.0
RISK_PER_TRADE_PCT=0.02             # 2% = ₹500 target risk per trade
MAX_DAILY_LOSS_PCT=0.08             # 8% = ₹2,000 (allows 2 SL hits)
MAX_DAILY_LOSS_HARD=2500.0          # ₹2,500 absolute hard stop
MAX_TRADES_PER_DAY=4
MAX_DRAWDOWN_PCT=20.0               # Halt if drawdown > 20% from peak
MAX_CONSECUTIVE_LOSSES=8            # High ceiling (drawdown halt is primary)
MAX_LOTS=1
LOT_SIZE=65

# ─── Engine: daily_adaptive (matches daily backtest) vs intraday (5m ORB/VWAP) ──
TRADING_ENGINE=daily_adaptive
DAILY_STRATEGY_FILTER=BOTH
NIFTY_OPTION_LOT_SIZE=75
DAILY_BASE_LOTS=1
DAILY_ADAPTIVE_WINDOW_START=09:16
DAILY_ADAPTIVE_WINDOW_END=10:30

# ─── Strategy Params (backtest-optimized) ────────────────────────
VIX_MAX=28.0
ATR_SL_MIN_PCT=0.20
ATR_SL_MAX_PCT=0.30
RR_MIN=2.0
RSI_BULL_MIN=40.0
RSI_BEAR_MAX=60.0
ENTRY_WINDOW_CLOSE=10:00
RECLAIM_WINDOW_END=13:30

# ─── Execution ───────────────────────────────────────────────────
USE_LIMIT_ORDERS=true               # Aggressive limit (LTP + buffer)
LIMIT_PRICE_BUFFER_PCT=0.005        # 0.5% above LTP
USE_SLM_EXIT=true                   # SL-M at exchange level
PAPER_MODE=false                    # LIVE

# ─── Notifications ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Environment ──────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
